[Unit]
Description=Edge AI Navigation Service
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/edge-ai-navigation

ExecStart=/home/pi/edge-ai-navigation/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target